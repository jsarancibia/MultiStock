# Copia este archivo a .env.local y pega los valores de tu proyecto en https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Migraciones (npm run db:push): URI de Postgres desde el Dashboard → Settings → Database → Connection string → URI
# Recomendado: pooler (puerto 6543, modo Session). La contraseña es la del proyecto (no la anon key).
# SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Correo de contacto para contrataciones y soporte
# NEXT_PUBLIC_SALES_EMAIL=multistock.dev@gmail.com

# Zona horaria para reportes Excel (ej: America/Santiago, America/Argentina/Buenos_Aires)
# Si no se define, los reportes usan UTC por defecto.
APP_TIMEZONE=America/Santiago

# Limpieza de datos (npm run db:wipe:business o db:wipe:full): usa la misma SUPABASE_DB_URL y requiere psql en el PATH.
